# Copy to `.env` and adjust. Variables prefixed PUBLIC_ are exposed to the
# browser; anything without the prefix stays server-only.

# Public base URL of the deployed site (no trailing slash).
# Used to render the copyable "link this app" URL (`${PUBLIC_SITE_URL}/link`).
PUBLIC_SITE_URL=https://shuuen.xyz

# When the Go backend exists, the browser client will call it at same-origin
# `/api` (via the reverse proxy in prod, or Vite's dev proxy locally), so no
# API base URL is needed here. Server-only secrets (DB, session keys, upstream
# music-API keys) would go here WITHOUT the PUBLIC_ prefix once added.
