# Copy to `.env` and adjust. Variables prefixed PUBLIC_ are exposed to the
# browser; anything without the prefix stays server-only.

# Public base URL of the deployed site (no trailing slash).
# Used to render the copyable "link this app" URL (`${PUBLIC_SITE_URL}/link`).
PUBLIC_SITE_URL=https://shuuen.xyz

# Server-side auth routes call the Go backend directly. Defaults to this value
# if unset.
SHUUEN_BACKEND_URL=http://127.0.0.1:9999

# Browser client code calls the backend at same-origin `/api` (via the reverse
# proxy in prod, or Vite's dev proxy locally), so no public API base URL is
# needed here. Server-only secrets (DB, session keys, upstream music-API keys)
# go here WITHOUT the PUBLIC_ prefix.
